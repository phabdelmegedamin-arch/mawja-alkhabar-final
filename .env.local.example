# ── Supabase ──────────────────────────────────────
# من: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Claude / Anthropic ────────────────────────────
# من: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
NEXT_PUBLIC_CLAUDE_MODEL=claude-sonnet-4-6

# ── Admin Auth ────────────────────────────────────
# SHA-256 hashes — لا تضع كلمات المرور نفسها
ADMIN_USERNAME_HASH=9057f652e4dadfb37f55190933bfdd604114c9e287affcf78c6e60c9c5e4a207
ADMIN_EMAIL_HASH=ca2063aba4ae4f5de66f7d7c31bee2d5e6042ded0ca6b592b2133257c7ded2cc
ADMIN_PASSWORD_HASH=c9703d888f4e747ffff62688991200b03b0c0f43ba85ce9822027254ed6dc71a
ADMIN_PASSWORD2_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92

# ── JWT Session ───────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Payment — Moyasar ────────────────────────────
NEXT_PUBLIC_MOYASAR_KEY=pk_live_...
MOYASAR_SECRET_KEY=sk_live_...

# ── Plans Pricing (SAR) ──────────────────────────
NEXT_PUBLIC_PRICE_MONTHLY=49
NEXT_PUBLIC_PRICE_YEARLY=399
NEXT_PUBLIC_VAT_RATE=0.15

# ── RSS Proxy ────────────────────────────────────
RSS2JSON_API_KEY=your_rss2json_key_optional

# ── Feature Flags ────────────────────────────────
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_LIVE_PRICES=true
NEXT_PUBLIC_FREE_TICKER=2222
